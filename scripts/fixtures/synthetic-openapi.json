{
  "openapi": "3.0.0",
  "info": {
    "title": "Synthetic SolvaPay API",
    "version": "1.0.0"
  },
  "paths": {
    "/v1/sdk/customers": {
      "get": {
        "operationId": "listCustomers",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Customer"
                }
              }
            }
          }
        }
      }
    },
    "/v1/sdk/agents": {
      "get": {
        "operationId": "listAgents",
        "responses": {
          "200": {
            "description": "agents"
          }
        }
      }
    },
    "/v1/admin/users": {
      "get": {
        "operationId": "listUsers",
        "responses": {
          "200": {
            "description": "admin"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "city": {
            "type": "string"
          }
        }
      },
      "OrphanSchema": {
        "type": "boolean"
      },
      "zLast": {
        "type": "number"
      }
    }
  }
}
