{
  "name": "@example/mcp-checkout-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env INPUT=mcp-app.html vite build && tsc",
    "serve": "tsx src/index.ts",
    "dev": "concurrently \"cross-env INPUT=mcp-app.html vite build --watch\" \"tsx watch --clear-screen=false --include .env --include dist/mcp-app.html --include '../../packages/*/src/**/*.ts' --include '../../packages/*/src/**/*.tsx' src/index.ts\"",
    "tunnel": "node ../shared/tunnel.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solvapay/core": "workspace:*",
    "@solvapay/mcp": "workspace:*",
    "@solvapay/mcp-core": "workspace:*",
    "@solvapay/react": "workspace:*",
    "@solvapay/server": "workspace:*",
    "@stripe/stripe-js": "^9.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "rollup": "^4.62.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
