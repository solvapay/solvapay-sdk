MCP_PORT=3006
MCP_HOST=localhost
# Public URL this MCP server is reachable at. The OAuth bridge publishes
# this in Protected-Resource / Authorization-Server metadata, so it must
# be reachable from the MCP client (Claude Desktop, MCP Inspector, etc.).
#
# Local-only (works for MCP Inspector on the same machine):
# MCP_PUBLIC_BASE_URL=http://localhost:3006
#
# Through ngrok (required for Claude Desktop or any remote MCP client).
# Reserve `mcpapp.your-subdomain.ngrok.app` in ngrok and add the matching
# tunnel to `solvapay-backend/ngrok.yml`. The hostname is kept short because
# corporate DNS filters (Cisco Umbrella etc.) flag `checkout`/`payment`-themed
# ngrok subdomains as phishing and serve a 403 block page, which MCP clients
# surface as "HTTP 500 loading OAuth metadata".
MCP_PUBLIC_BASE_URL=https://mcpapp.your-subdomain.ngrok.app
SOLVAPAY_API_BASE_URL=http://localhost:3001
SOLVAPAY_PRODUCT_REF=
SOLVAPAY_SECRET_KEY=

# Register the two demo paywalled data tools (search_knowledge, get_market_quote)
# and their slash-command prompts. Leave unset (or "true") in dev to exercise
# the paywall end-to-end from an MCP host; set to "false" when you copy this
# example into your own repo as a starting template so the demo tools don't
# leak into your production surface.
DEMO_TOOLS=true

# Extra origins the iframe is allowed to load resources (img / style / font)
# from, merged into the CSP's `resource_domains`. Comma-separated list of bare
# origins (scheme + host + port — no paths).
#
# In local dev the backend admin serves provider-uploaded merchant logos from
# `http://localhost:<port>/ui/files/download/...`, so you'd add those origins
# here to see the logo in the iframe. The API origin (SOLVAPAY_API_BASE_URL)
# is always included, no need to repeat it.
#
# Leave unset in production — keep the CSP tight.
# MCP_ASSET_ORIGINS=http://localhost:6274,http://localhost:3001
