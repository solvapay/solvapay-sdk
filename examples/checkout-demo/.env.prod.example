# Production deploy — copy to .env.prod (gitignored).
# Used by `pnpm build:opennext:prod` (NEXT_PUBLIC_* baked at build time)
# and optionally by `scripts/deploy.mjs` for SOLVAPAY_API_BASE_URL --var override.

# Build-time (client bundle) — baked in by pnpm build:opennext:prod
# Aliases NEXT_PUBLIC_PRODUCT_REF / SOLVAPAY_PRODUCT_REF work via next.config.mjs
NEXT_PUBLIC_SOLVAPAY_PRODUCT_REF=prd_your_product_ref
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Deploy-time var (not a secret) — must match SOLVAPAY_SECRET_KEY environment:
#   sandbox/dev keys → https://api-dev.solvapay.com
#   live keys        → https://api.solvapay.com
# web-app-demo uses the dev API + sandbox secret on the production Worker.
SOLVAPAY_API_BASE_URL=https://api-dev.solvapay.com

# Secrets — set via wrangler secret put, NOT in this file:
# SOLVAPAY_SECRET_KEY
# SUPABASE_JWT_SECRET
