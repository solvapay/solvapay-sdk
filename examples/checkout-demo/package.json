{
  "name": "checkout-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev-with-tunnel.sh",
    "dev:local": "NODE_OPTIONS='--disable-warning=DEP0205' next dev --port 3010",
    "dev:tunnel": "bash scripts/dev-with-tunnel.sh",
    "build": "next build",
    "build:opennext": "opennextjs-cloudflare build",
    "build:opennext:prod": "dotenv -e .env.prod -- opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "serve:local": "wrangler dev",
    "start": "next start",
    "predeploy:cf": "pnpm -w build:packages && pnpm build:opennext",
    "deploy:cf": "node scripts/deploy.mjs",
    "deploy:cf:prod": "pnpm -w build:packages && pnpm build:opennext:prod && node scripts/deploy.mjs --prod",
    "lint": "pnpm exec eslint . --ignore-pattern .next --ignore-pattern .open-next --ignore-pattern next-env.d.ts --ignore-pattern postcss.config.mjs"
  },
  "dependencies": {
    "@solvapay/auth": "workspace:*",
    "@solvapay/core": "workspace:*",
    "@solvapay/next": "workspace:*",
    "@solvapay/react": "workspace:*",
    "@solvapay/react-supabase": "workspace:*",
    "@solvapay/server": "workspace:*",
    "@stripe/react-stripe-js": "^6.0.0",
    "@supabase/supabase-js": "^2.105.1",
    "jose": "^6.2.2",
    "next": "^16.2.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.3",
    "dotenv-cli": "^8.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
