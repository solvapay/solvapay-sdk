{
  "name": "@example/mcp-oauth-bridge",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch scripts --watch ../../packages/server/dist --watch ../../packages/core/dist --ext ts,js,mjs --exec \"tsx src/index.ts\"",
    "build": "tsup src/index.ts --format esm",
    "oauth:flow": "tsx scripts/run-oauth-flow.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.2",
    "@solvapay/core": "workspace:*",
    "@solvapay/demo-services": "workspace:*",
    "@solvapay/server": "workspace:*",
    "dotenv": "^17.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "nodemon": "^3.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
