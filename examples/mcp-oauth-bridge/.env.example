MCP_PORT=3004
MCP_HOST=0.0.0.0

# Local MCP server origin shown to clients
MCP_PUBLIC_BASE_URL=http://localhost:3004

# SolvaPay backend API base URL (used for OAuth endpoints and SDK API calls)
SOLVAPAY_API_BASE_URL=http://localhost:3000

# Product reference used by payable.mcp and OAuth DCR endpoint construction
SOLVAPAY_PRODUCT_REF=basic-crud

# Required: backend API key for payable/check limits calls
SOLVAPAY_SECRET_KEY=

# Required: webhook signing secret for verifying incoming SolvaPay events
SOLVAPAY_WEBHOOK_SECRET=

# OAuth flow script callback URL (must pass DCR policy)
OAUTH_REDIRECT_URI=http://localhost:6274/oauth/callback/debug

# Anthropic API key for agent benchmark (scripts/run-benchmark.local.sh)
ANTHROPIC_API_KEY=
