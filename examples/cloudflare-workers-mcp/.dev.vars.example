# Local wrangler dev secrets. Copy to `.dev.vars` and fill in your own
# values, then `pnpm serve:local` will pick them up automatically.
#
# Production values live in `wrangler.jsonc` (non-secrets) + `wrangler
# secret put SOLVAPAY_SECRET_KEY` (secrets). The `vars` block in
# wrangler.jsonc overrides matching keys here at deploy time.

# The SolvaPay secret key for your merchant account. Never check this
# in. Get it from the SolvaPay dashboard -> API Keys.
SOLVAPAY_SECRET_KEY=sk_test_your_key_here

# The product ref the paywall gates on. Create one in the SolvaPay
# dashboard -> Products and copy its `prd_…` ID.
SOLVAPAY_PRODUCT_REF=prd_your_product_ref

# Public origin this worker answers at. For `wrangler dev`,
# http://localhost:8787 is fine. For deployed runs, the canonical URL
# (e.g. https://mcp-workers-example.solvapay.com).
MCP_PUBLIC_BASE_URL=http://localhost:8787

# SolvaPay API origin. Omit / leave blank to use the SolvaPay backend
# (https://api-dev.solvapay.com). Set explicitly to point at a
# different environment (e.g. a preview backend).
# SOLVAPAY_API_BASE_URL=https://api-dev.solvapay.com

# Flip to "false" to skip registering the paywalled demo tools
# (predict_price_chart, predict_direction — toy stock-predictor
# oracle) when using this example as a template for your own MCP
# server.
DEMO_TOOLS=1
