{
  "name": "chat-checkout-demo",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3011",
    "build": "vite build",
    "build:prod": "vite build --mode prod",
    "preview": "vite preview --port 3011",
    "serve:local": "wrangler dev",
    "predeploy": "pnpm -w build:packages && pnpm build",
    "deploy": "node scripts/deploy.mjs",
    "deploy:prod": "pnpm -w build:packages && pnpm build:prod && node scripts/deploy.mjs --prod"
  },
  "dependencies": {
    "@google/genai": "^1.21.0",
    "@solvapay/auth": "workspace:^",
    "@solvapay/core": "workspace:*",
    "@solvapay/react": "workspace:*",
    "@solvapay/server": "*",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.5",
    "react-markdown": "9.0.1",
    "remark-gfm": "4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251124.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.6",
    "wrangler": "^4.47.0"
  }
}
