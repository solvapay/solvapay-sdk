# SolvaPay backend (server-side; never exposed to the browser)
SOLVAPAY_SECRET_KEY=sk_test_...
# Optional: override the SolvaPay API base URL (defaults to production)
# SOLVAPAY_API_BASE_URL=https://api.solvapay.com

# Gemini API key — server-side only. The /api/chat route proxies all chat
# traffic so the key is never shipped to the browser.
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# The demo discovers each scenario's plans from its product on demand:
# - 1 plan on the product → auto-picked
# - 2+ plans → an inline picker is rendered before the payment fields
#
# Each product needs at least one plan in the SolvaPay dashboard. The free
# tier (number of free messages before the paywall trips) is read from the
# active plan's `freeUnits` field — set this on a free default plan or on
# whichever plan represents the unauthenticated baseline.

# Subscription scenario (intended: a recurring plan)
VITE_SUBSCRIPTION_PRODUCT_REF=prd_...

# Day Pass scenario (intended: a one-time plan)
VITE_DAYPASS_PRODUCT_REF=prd_...

# Top-up scenario (credits). Configure one usage-based plan with a credit
# meter, plus one one-time plan per credit pack you want to offer (each
# pack's `name` and `price` drive the picker UI).
VITE_TOPUP_PRODUCT_REF=prd_...
