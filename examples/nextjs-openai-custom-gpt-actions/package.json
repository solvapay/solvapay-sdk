{
  "name": "@example/nextjs-openai-custom-gpt-actions",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm generate:docs && next dev",
    "build": "pnpm generate:docs && next build",
    "start": "next start",
    "lint": "next lint",
    "generate:docs": "tsx scripts/generate-zod-openapi.ts",
    "dev:docs": "pnpm generate:docs && next dev",
    "init:db": "tsx scripts/init-db.ts",
    "setup": "pnpm install && pnpm setup:env && pnpm build:deps",
    "setup:env": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env.local')){fs.writeFileSync('.env.local','SOLVAPAY_API_KEY=demo-key-for-development\\nSOLVAPAY_PRODUCT=custom-gpt-actions\\n'); console.log('✅ Created .env.local file');}\"",
    "build:deps": "cd ../.. && pnpm build:packages",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:ui-components": "vitest run src/__tests__/ui/",
    "test:ui-watch": "vitest src/__tests__/ui/",
    "test:backend": "vitest run src/__tests__/backend/",
    "test:backend-watch": "vitest src/__tests__/backend/",
    "clean": "rm -rf node_modules .next .env.local",
    "clean:ports": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@solvapay/auth": "workspace:*",
    "@solvapay/core": "workspace:*",
    "@solvapay/next": "workspace:*",
    "@solvapay/react": "workspace:*",
    "@solvapay/react-supabase": "workspace:*",
    "@solvapay/server": "workspace:*",
    "@supabase/supabase-js": "^2.100.1",
    "dotenv": "^17.3.1",
    "jose": "^6.2.2",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^29.0.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
