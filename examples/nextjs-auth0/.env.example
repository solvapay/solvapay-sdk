AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Generate with: openssl rand -hex 32
AUTH0_SECRET=
# This app always runs on localhost — not ngrok.
APP_BASE_URL=http://localhost:3013

# SolvaPay server credentials (server-only). API base is separate from APP_BASE_URL:
# - hosted dev: `npx solvapay@latest init --dev` → https://api-dev.solvapay.com
# - local backend: `SOLVAPAY_API_BASE_URL=https://api.<you>.ngrok.app npx solvapay init`
SOLVAPAY_SECRET_KEY=
SOLVAPAY_API_BASE_URL=https://api-dev.solvapay.com
SOLVAPAY_PRODUCT_REF=
# Product ref exposed to the browser for the embedded checkout (same value)
NEXT_PUBLIC_SOLVAPAY_PRODUCT_REF=
