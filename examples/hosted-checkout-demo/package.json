{
  "name": "hosted-checkout-demo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "[ -e '.env' ] || cp env.example .env && next build",
    "start": "next start",
    "lint": "pnpm exec eslint . --ignore-pattern .next --ignore-pattern next-env.d.ts --ignore-pattern postcss.config.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solvapay/auth": "workspace:*",
    "@solvapay/core": "workspace:*",
    "@solvapay/next": "workspace:*",
    "@solvapay/react": "workspace:*",
    "@solvapay/react-supabase": "workspace:*",
    "@solvapay/server": "workspace:*",
    "@stripe/react-stripe-js": "^6.0.0",
    "@supabase/supabase-js": "^2.105.1",
    "jose": "^6.2.2",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
