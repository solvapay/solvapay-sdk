# Copy this file to Supabase function secrets (NOT an .env file — Edge
# Functions read from the Supabase secret store, not the filesystem):
#
#   supabase secrets set \
#     SOLVAPAY_SECRET_KEY=sk_live_… \
#     SOLVAPAY_PRODUCT_REF=prod_… \
#     MCP_PUBLIC_BASE_URL=https://<project>.supabase.co/functions/v1/mcp

# Server-side SolvaPay API key. Never exposed to the iframe — the MCP
# function is the only consumer.
SOLVAPAY_SECRET_KEY=sk_live_replace_me

# The SolvaPay product the MCP server paywalls. Every `registerPayable`
# tool call is metered against this product.
SOLVAPAY_PRODUCT_REF=prod_replace_me

# Public origin the MCP server is deployed at. MUST match what MCP
# clients advertise in their OAuth redirect_uri — the OAuth bridge
# stamps this as `issuer` in /.well-known/oauth-authorization-server
# and every published endpoint URL starts with it.
MCP_PUBLIC_BASE_URL=https://your-project.supabase.co/functions/v1/mcp

# Optional — override the SolvaPay API origin (staging / local). Defaults
# to https://api.solvapay.com.
# SOLVAPAY_API_BASE_URL=https://api.solvapay.com

# Optional — set to "false" to skip registering the paywalled demo tools
# (predict_price_chart, predict_direction — the Goldberg stock-predictor
# Oracle) when using this example as a template for your own MCP server.
# Defaults to "true" in the demo.
# DEMO_TOOLS=true
