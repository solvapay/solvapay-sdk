# Product reference exposed to the client (PlanSelector.Root productRef)
NEXT_PUBLIC_PRODUCT_REF=prd_demo

# Optional: set a real SolvaPay secret key to swap the stub for the real backend.
# When unset, the example routes every @solvapay/next helper through the
# bundled stub client from @solvapay/examples-shared/next-stub.
# SOLVAPAY_SECRET_KEY=
