# Cloudflare Worker secrets — uploaded once via `wrangler secret put`
# and persisted per-Worker. Listed here so `wrangler dev` can pick
# them up locally; `scripts/deploy.mjs` does NOT re-upload secrets on
# every deploy.

# SolvaPay backend (server-side; never exposed to the browser).
SOLVAPAY_SECRET_KEY=sk_test_...

# Gemini API key — server-side only. The /api/chat route proxies all
# chat traffic so the key is never shipped to the browser.
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the SolvaPay API base URL (defaults to production).
# Forwarded to `wrangler deploy --var SOLVAPAY_API_BASE_URL:<value>`
# at deploy time so it overrides the placeholder in wrangler.jsonc.
# SOLVAPAY_API_BASE_URL=https://api.solvapay.com
