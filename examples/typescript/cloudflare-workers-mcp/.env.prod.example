# Live values for the goldberg-demo prod Worker.
#
# `pnpm deploy:prod` (scripts/deploy.mjs --prod) sources this file and
# passes the overridable vars through to:
#   wrangler deploy --env production --var KEY:VALUE …
#
# SOLVAPAY_SECRET_KEY is NOT re-uploaded on each deploy. Set it once:
#   pnpm exec wrangler secret put SOLVAPAY_SECRET_KEY --env production
# It persists across deploys on the prod Worker (solvapay-mcp-goldberg-prod).
# Kept here so `wrangler dev --env production` can read it for the
# (rare) case of running prod config locally.
#
# Copy this file to `.env.prod` and fill in real live values. The
# copy is gitignored; never commit it.

# LIVE merchant secret key (sk_live_…). Dashboard -> API Keys (Live).
SOLVAPAY_SECRET_KEY=sk_live_your_live_key_here

# LIVE product ref the paywall gates on (prd_…). Must be a product
# created on the live merchant account, not the test/sandbox one.
SOLVAPAY_PRODUCT_REF=prd_your_live_product_ref

# Canonical public URL the prod Worker answers at. Used by the OAuth
# `issuer` and the MCP `publicBaseUrl`. Leave as-is unless you're
# pointing the prod deploy at a different hostname.
MCP_PUBLIC_BASE_URL=https://goldberg-demo.solvapay.app

# SolvaPay API origin. Leave blank to use production
# (https://api.solvapay.com — src/worker.ts default). Set explicitly
# only if you need to point the prod Worker at a different backend.
# SOLVAPAY_API_BASE_URL=

# Keep the demo tools (predict_price_chart, predict_direction)
# registered on the live demo. Flip to "0" to retire them.
DEMO_TOOLS=1
