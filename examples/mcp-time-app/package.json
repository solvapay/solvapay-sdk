{
  "name": "@example/mcp-time-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env INPUT=mcp-app.html vite build && tsc",
    "serve": "tsx src/index.ts",
    "dev": "concurrently \"cross-env INPUT=mcp-app.html vite build --watch\" \"nodemon --watch src --watch dist/mcp-app.html --ext ts,css,html --exec \\\"tsx src/index.ts\\\"\""
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.24.2",
    "@solvapay/core": "1.0.0-preview.21",
    "@solvapay/server": "1.0.0-preview.21",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.0",
    "rollup": "^4.59.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
