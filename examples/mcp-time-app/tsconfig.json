{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "outDir": "dist",
    "composite": false,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  }
}
