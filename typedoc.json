{
  "$schema": "https://typedoc.org/schema.json",
  "tsconfig": "tsconfig.docs.json",
  "entryPoints": [
    "packages/core/src/index.ts",
    "packages/server/src/index.ts",
    "packages/fetch/src/index.ts",
    "packages/mcp-core/src/index.ts",
    "packages/mcp/src/index.ts",
    "packages/mcp-express/src/index.ts",
    "packages/mcp-fetch/src/index.ts",
    "packages/react/src/index.tsx",
    "packages/react-supabase/src/index.ts",
    "packages/next/src/index.ts",
    "packages/auth/src/index.ts"
  ],
  "out": "docs/api",
  "readme": "none",
  "name": "SolvaPay SDK",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx", "**/node_modules/**"],
  "categorizeByGroup": true,
  "categoryOrder": ["Core", "Server", "React", "Next.js", "Auth", "*"],
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "default",
  "githubPages": false,
  "gitRevision": "main",
  "gitRemote": "origin"
}
