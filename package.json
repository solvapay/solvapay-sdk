{
  "name": "solvapay-sdk-monorepo",
  "version": "1.0.0",
  "description": "A modern TypeScript SDK for monetizing APIs, AI agents, and MCP servers with paywall protection and subscription management",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/solvapay/solvapay-sdk.git"
  },
  "homepage": "https://github.com/solvapay/solvapay-sdk#readme",
  "bugs": {
    "url": "https://github.com/solvapay/solvapay-sdk/issues"
  },
  "keywords": [
    "solvapay",
    "sdk",
    "typescript",
    "paywall",
    "subscription",
    "payment",
    "monetization",
    "api",
    "mcp",
    "nextjs",
    "react",
    "express"
  ],
  "author": "SolvaPay Inc.",
  "license": "MIT",
  "scripts": {
    "build": "turbo build --concurrency 16",
    "build:examples": "turbo build --filter=@example/*",
    "build:packages": "turbo build --filter=@solvapay/* --filter=solvapay",
    "clean": "turbo clean",
    "dev": "turbo dev --no-cache --concurrency 16 --continue",
    "test": "turbo run test --filter=!@example/*",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "release": "turbo run release",
    "version:bump": "tsx scripts/version-bump.ts",
    "version:bump:minor": "tsx scripts/version-bump.ts minor",
    "version:bump:major": "tsx scripts/version-bump.ts major",
    "version:bump:preview": "tsx scripts/version-bump-preview.ts",
    "version:sync": "tsx scripts/sync-versions-from-tags.ts",
    "version:sync:preview": "tsx scripts/sync-versions-from-tags.ts --preview",
    "test:publish": "tsx scripts/test-publish.ts",
    "publish:packages": "pnpm --filter=@solvapay/* --filter=solvapay publish --access public --no-git-checks --no-provenance",
    "publish:preview": "pnpm --filter=@solvapay/* --filter=solvapay publish --tag preview --access public --no-git-checks --no-provenance",
    "publish:preview:dry-run": "pnpm --filter=@solvapay/* --filter=solvapay publish --tag preview --access public --no-git-checks --no-provenance --dry-run",
    "tag:latest": "tsx scripts/tag-as-latest.ts",
    "docs:build": "rm -rf docs/api && typedoc",
    "docs:build:preview": "rm -rf docs/api && typedoc",
    "docs:watch": "typedoc --watch",
    "docs:check": "typedoc --json docs/api.json",
    "docs:validate-links": "tsx scripts/validate-doc-links.ts",
    "docs:validate": "pnpm docs:validate-links && pnpm docs:check && pnpm docs:build",
    "deps:check": "tsx scripts/check-dependency-health.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fastify": "^5.8.4",
    "glob": "^13.0.6",
    "jose": "^6.2.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
