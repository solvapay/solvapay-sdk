{
  "name": "solvapay-sdk-monorepo",
  "version": "1.0.0",
  "description": "A modern TypeScript SDK for monetizing APIs, AI agents, and MCP servers with paywall protection and subscription management",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/solvapay/solvapay-sdk.git"
  },
  "homepage": "https://github.com/solvapay/solvapay-sdk#readme",
  "bugs": {
    "url": "https://github.com/solvapay/solvapay-sdk/issues"
  },
  "keywords": [
    "solvapay",
    "sdk",
    "typescript",
    "paywall",
    "subscription",
    "payment",
    "monetization",
    "api",
    "mcp",
    "nextjs",
    "react",
    "express"
  ],
  "author": "SolvaPay Inc.",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "next": "16.2.7"
    }
  },
  "scripts": {
    "build": "turbo build --concurrency 16",
    "build:examples": "turbo build --filter=@example/*",
    "build:packages": "turbo build --filter=@solvapay/* --filter=solvapay --filter=create-solvapay",
    "clean": "turbo clean",
    "dev": "turbo dev --no-cache --concurrency 16 --continue",
    "test": "turbo run test --filter=!@example/*",
    "lint": "turbo run lint",
    "typecheck": "tsx scripts/typecheck-packages.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "release": "turbo run release",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status",
    "changeset:snapshot": "changeset version --snapshot preview && changeset publish --tag preview --no-git-tag",
    "validate:fetch-runtime": "tsx scripts/validate-fetch-runtime.ts",
    "docs:build": "rm -rf docs/api && typedoc",
    "docs:build:preview": "rm -rf docs/api && typedoc",
    "docs:watch": "typedoc --watch",
    "docs:check": "typedoc --json docs/api.json",
    "docs:validate-links": "tsx scripts/validate-doc-links.ts",
    "docs:validate": "pnpm docs:validate-links && pnpm docs:check && pnpm docs:build",
    "deps:check": "tsx scripts/check-dependency-health.ts",
    "loc": "tsx scripts/count-loc.ts",
    "test:contract": "vitest run scripts --exclude '**/shadow/selftest.test.ts'",
    "shadow:run": "tsx scripts/shadow/run-shadow.ts",
    "shadow:selftest": "vitest run scripts/shadow/",
    "snapshot:openapi": "tsx scripts/snapshot-openapi.ts",
    "snapshot:openapi:check": "tsx scripts/snapshot-openapi.ts --check",
    "manifest:validate": "tsx scripts/manifest.ts",
    "manifest:check": "tsx scripts/manifest.ts --check",
    "parity:check": "tsx scripts/parity-check.ts",
    "delegation:check": "tsx scripts/check-delegation.ts",
    "test:clean-install": "pnpm --filter @solvapay/server-native test:clean-install"
  },
  "devDependencies": {
    "@solvapay/core": "workspace:*",
    "@solvapay/mcp-core": "workspace:*",
    "@solvapay/server": "workspace:*",
    "@changesets/cli": "^2.27.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fastify": "^5.8.4",
    "glob": "^13.0.6",
    "jose": "^6.2.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  }
}
