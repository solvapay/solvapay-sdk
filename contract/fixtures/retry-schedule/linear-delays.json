{
  "suite": "retry-schedule",
  "case": "linear-delays",
  "input": {
    "fn": "withRetry",
    "args": {
      "attempts": [
        { "throw": "boom" },
        { "throw": "boom" },
        { "throw": "boom" },
        { "throw": "boom" },
        { "throw": "boom" }
      ],
      "options": { "maxRetries": 4, "backoffStrategy": "linear" }
    }
  },
  "expect": {
    "result": {
      "delays": [500, 1000, 1500, 2000],
      "events": [
        "call:0",
        "sleep:500",
        "call:1",
        "sleep:1000",
        "call:2",
        "sleep:1500",
        "call:3",
        "sleep:2000",
        "call:4"
      ],
      "outcome": { "type": "rejected", "name": "Error", "message": "boom" }
    }
  }
}
