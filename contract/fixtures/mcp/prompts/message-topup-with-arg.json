{
  "suite": "mcp",
  "case": "message-topup-with-arg",
  "input": {
    "fn": "buildPromptUserMessage",
    "args": {
      "promptName": "topup",
      "args": {
        "amount": "25"
      }
    }
  },
  "expect": {
    "result": {
      "messages": [
        {
          "role": "user",
          "content": {
            "type": "text",
            "text": "Top up my SolvaPay credits by 25."
          }
        }
      ]
    }
  }
}
