{
  "suite": "paywall",
  "case": "payment-minimal",
  "input": {
    "fn": "buildPaywallGate",
    "args": {
      "productRef": "prd_demo",
      "limits": {
        "plan": "pl_basic",
        "remaining": 0,
        "checkoutUrl": "https://pay.test/x"
      }
    }
  },
  "expect": {
    "result": {
      "kind": "payment_required",
      "product": "prd_demo",
      "checkoutUrl": "https://pay.test/x",
      "message": "You don't have an active plan for this tool. Call the `upgrade` tool to pick a plan, or open https://pay.test/x in a browser."
    }
  }
}
