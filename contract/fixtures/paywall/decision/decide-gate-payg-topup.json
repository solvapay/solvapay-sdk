{
  "suite": "paywall",
  "case": "decide-gate-payg-topup",
  "input": {
    "fn": "decidePaywallOutcome",
    "args": {
      "withinLimits": false,
      "product": "prd_demo",
      "limits": {
        "plan": "pl_pro",
        "remaining": 0,
        "checkoutUrl": "https://pay.test/x",
        "plans": [
          { "reference": "pl_pro", "type": "usage-based", "requiresPayment": true },
          { "reference": "pl_hybrid", "type": "hybrid", "requiresPayment": true }
        ],
        "balance": { "creditBalance": 0, "creditsPerUnit": 1, "currency": "usd" }
      }
    }
  },
  "expect": {
    "result": {
      "outcome": "gate",
      "gate": {
        "kind": "activation_required",
        "product": "prd_demo",
        "message": "You're out of credits. Call the `topup` tool to add more, or open https://pay.test/x in a browser.",
        "checkoutUrl": "https://pay.test/x",
        "plans": [
          { "reference": "pl_pro", "type": "usage-based", "requiresPayment": true },
          { "reference": "pl_hybrid", "type": "hybrid", "requiresPayment": true }
        ],
        "balance": { "creditBalance": 0, "creditsPerUnit": 1, "currency": "usd" }
      }
    }
  }
}
