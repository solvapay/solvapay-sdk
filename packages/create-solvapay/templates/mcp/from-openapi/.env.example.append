
# Upstream credentials the generated tool handlers send to the API.
# Uncomment/fill the shape scaffold wrote to your generated `.env`:
#
# - bearer or single apiKey-header auth -> UPSTREAM_API_KEY
# - apiKey-multi auth -> UPSTREAM_API_HEADERS compact JSON
#
# `UPSTREAM_API_HEADERS` is uploaded as one Worker Secret and parsed by
# generated tools, so keep it on one line with real header values.
# UPSTREAM_API_KEY=
# UPSTREAM_API_HEADERS={"x-client-id":"...","x-client-secret":"..."}

# OAuth 2.0 client_credentials — only present when the OpenAPI spec
# uses `oauth2` with the `clientCredentials` flow. Scaffold populates
# these from `selections.upstreamAuth.{tokenUrl,clientId,clientSecret,
# scope,audience}`. `src/lib/upstreamOAuth.ts` exchanges them for a
# short-lived bearer token cached in the Workers isolate. `SCOPE` and
# `AUDIENCE` are optional and only written when the user supplied them.
# UPSTREAM_OAUTH_TOKEN_URL=
# UPSTREAM_OAUTH_CLIENT_ID=
# UPSTREAM_OAUTH_CLIENT_SECRET=
# UPSTREAM_OAUTH_SCOPE=
# UPSTREAM_OAUTH_AUDIENCE=
