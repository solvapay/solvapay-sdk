# Local values for this Worker — used in two places:
#
#   1. `npm run serve:local` / `wrangler dev` picks these up automatically
#      for local testing.
#   2. `npm run deploy` (see scripts/deploy.mjs) sources `.env` and passes
#      SOLVAPAY_PRODUCT_REF / MCP_PUBLIC_BASE_URL / SOLVAPAY_API_BASE_URL
#      as `--var` overrides at deploy time.
#
# Copy this file to `.env` and fill in your real values. `.env` is
# gitignored; keep secrets out of git.

# The SolvaPay secret key for your merchant account. Never commit.
# Populated by `npx solvapay init`. Uploaded to Cloudflare as a Worker
# Secret automatically on the first `npm run deploy`.
SOLVAPAY_SECRET_KEY=sk_test_your_key_here

# Product ref the paywall gates on. Create one in the SolvaPay Console
# under Products and copy its `prd_…` ID. Populated by scaffold.
SOLVAPAY_PRODUCT_REF=__SOLVAPAY_PRODUCT_REF__

# Canonical public URL this Worker answers at. For `wrangler dev`,
# http://localhost:8787 is fine. For deployed runs on workers.dev,
# deploy.mjs auto-resolves https://<worker>.<subdomain>.workers.dev
# before the first deploy when this is still the localhost placeholder.
# For custom domains, set explicitly before deploy.
MCP_PUBLIC_BASE_URL=__MCP_PUBLIC_BASE_URL__

# SolvaPay API origin. Omit / leave blank to use production
# (https://api.solvapay.com — src/worker.ts falls back to this).
# SOLVAPAY_API_BASE_URL=https://api-dev.solvapay.com
