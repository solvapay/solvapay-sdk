{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true
  },
  // Worker TS: check the Worker entrypoint, the generated tool registry,
  // and the asset-module declaration. The widget source (`src/mcp-app.tsx`)
  // is transpiled by vite during the iframe build and has its own type
  // drift against `@modelcontextprotocol/ext-apps`'s `McpAppFull` shape;
  // vite.config.ts uses Node globals (`process`) that the Workers TS
  // project doesn't pull in — both are excluded so the `tsc --noEmit`
  // signal is exactly "does the Worker compile?". Vite typechecks
  // itself when bundling the iframe.
  "include": ["src/worker.ts", "src/tools/**/*.ts", "src/lib/**/*.ts", "src/assets.d.ts"],
  "exclude": ["dist", ".wrangler", "src/assets", "src/mcp-app.tsx", "vite.config.ts"]
}
