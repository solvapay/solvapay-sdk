{
  "name": "@solvapay/demo-services",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tasks-service": {
      "types": "./dist/tasks-service.d.ts",
      "import": "./dist/tasks-service.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/tasks-service.ts --format esm --dts --tsconfig tsconfig.build.json"
  },
  "dependencies": {
    "@solvapay/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
