{
  "name": "create-paid-mcp-app",
  "version": "0.1.0",
  "description": "Scaffold a SolvaPay-monetized MCP server on Cloudflare Workers, from an OpenAPI spec or from scratch.",
  "type": "module",
  "bin": {
    "create-paid-mcp-app": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "scripts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/solvapay/solvapay-sdk.git",
    "directory": "packages/create-paid-mcp-app"
  },
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@solvapay/cli-core": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
