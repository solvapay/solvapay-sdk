{
  "name": "@solvapay/core",
  "version": "1.2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./business-details": {
      "types": "./dist/business-details-public.d.ts",
      "import": "./dist/business-details-public.js",
      "require": "./dist/business-details-public.cjs"
    }
  },
  "files": [
    "dist",
    "business-details-public.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/solvapay/solvapay-sdk.git",
    "directory": "packages/core"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts src/business-details-public.ts --format esm,cjs --dts --tsconfig tsconfig.build.json && cp business-details-public.d.ts dist/business-details-public.d.ts",
    "dev": "tsup src/index.ts src/business-details-public.ts --format esm,cjs --dts --tsconfig tsconfig.build.json --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:rust": "SOLVAPAY_IMPL=rust pnpm run test:unit",
    "test:unit:ts": "SOLVAPAY_IMPL=ts pnpm run test:unit",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
