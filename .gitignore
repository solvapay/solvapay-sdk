# Deno — written by `deno check` during the CI validate gate. We pin
# workspace imports to `@preview` dist-tags on purpose (mutable; each
# gate run should pick up the latest preview), so committing a lockfile
# here would defeat the regression-detection window.
deno.lock

# Code coverage
coverage/
*.lcov
.nyc_output

# Generated documentation (TypeDoc output)
docs/api/
docs/api.json

# Scratch research notes — internal, not for the public repo
research-tmp/

# Contract / snapshot CLI test scratch
scripts/.tmp/

# Shadow-mode live/selftest report output (step 25)
contract/shadow/output/

# Rust / Cargo build artifacts
rust/target/
**/*.rs.bk
*.pdb

# napi-rs Node binding (step 36) — native/WASI binaries (loaders are committed)
rust/bindings/node/*.node
rust/bindings/node/*.wasm
rust/bindings/node/node_modules/
rust/bindings/node/npm/**/*.node
rust/bindings/node/npm/**/*.wasm
